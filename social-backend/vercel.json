{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index?__path=/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/api/index?__path=/uploads/:path*"
    },
    {
      "source": "/",
      "destination": "/api/index?__path=/"
    },
    {
      "source": "/:path*",
      "destination": "/api/index?__path=/:path*"
    }
  ]
}
