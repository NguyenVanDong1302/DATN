PORT=4000
HOST=0.0.0.0
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/instagram_clone
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Comma-separated list of allowed frontend origins.
# Example: https://your-app.vercel.app,https://your-custom-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional single frontend origin. You can use this instead of, or alongside,
# CORS_ALLOWED_ORIGINS for a single deployed frontend.
FRONTEND_URL=

# Allow Vercel preview deployments (*.vercel.app) to access the API.
CORS_ALLOW_VERCEL_PREVIEWS=true

# Public base URL for uploaded media.
# In production this should be your public backend HTTPS URL,
# e.g. https://api.example.com
MEDIA_PUBLIC_BASE_URL=http://localhost:4000

# Optional local storage root for uploads.
# Free hosting usually uses ephemeral storage, so uploads can be lost on restart/redeploy.
MEDIA_STORAGE_ROOT=./public/uploads

# Optional moderation/admin settings
ADMIN_USERNAMES=admin
ADMIN_EMAILS=
AUTO_ADULT_MODERATION_ENABLED=true
ADULT_MODERATION_SCORE_THRESHOLD=6
ADULT_PROVIDER_SCORE_THRESHOLD=70
ADULT_MODERATION_PROVIDER_URL=
ADULT_MODERATION_PROVIDER_TOKEN=
ADULT_MODERATION_PROVIDER_TIMEOUT_MS=15000
AUTO_MODERATION_MAX_PROCESSING_MS=20000
AUTO_MODERATION_WORKER_INTERVAL_MS=5000
AUTO_MODERATION_WORKER_BATCH_SIZE=5
STORY_VIDEO_MAX_DURATION_SECONDS=60
